                                  <Value>="Tổng nhân viên: " &amp; Count(Fields!MaNV.Value) 
&amp; vbCrLf &amp; 
"Ngày in: " &amp; Format(Now, "dd/MM/yyyy HH:mm") 
&amp; vbCrLf &amp; 
"Người lập: " &amp; User!UserID</Value>
                                  <Style>
